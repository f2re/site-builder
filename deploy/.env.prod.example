# /srv/site-builder/.env.prod
# Скопировать на сервер и заполнить реальными значениями
# chmod 600 /srv/site-builder/.env.prod
# НИКОГДА не коммитить этот файл с реальными секретами!

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=sitebuilder
POSTGRES_USER=sb_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ── MeiliSearch ───────────────────────────────────────────────────────────────
MEILI_MASTER_KEY=CHANGE_ME_at_least_32_chars_master_key

# ── Backend (FastAPI) ─────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
FERNET_KEY=CHANGE_ME_run_python3_-c_from_cryptography.fernet_import_Fernet_print_Fernet.generate_key
DATABASE_URL=postgresql+asyncpg://sb_user:CHANGE_ME_strong_db_password@postgres:5432/sitebuilder
REDIS_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379/0

# ── Celery (отдельная Redis DB, та же нода) ───────────────────────────────────
CELERY_BROKER_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_strong_redis_password@redis:6379/1

# ── MeiliSearch (внутри Docker-сети) ─────────────────────────────────────────
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=CHANGE_ME_at_least_32_chars_master_key

# ── Frontend URLs (NUXT_PUBLIC_* = доступны и браузеру, и SSR) ───────────────
# ВАЖНО: NUXT_PUBLIC_* должны содержать публичные HTTPS-адреса!
# Браузер пользователя обращается по этим URL через Apache.
NUXT_PUBLIC_API_BASE=https://m.wifiobd.ru/api/v1
NUXT_PUBLIC_SITE_URL=https://m.wifiobd.ru
NUXT_PUBLIC_WS_BASE=wss://m.wifiobd.ru/ws/
NUXT_PUBLIC_MEILI_URL=https://m.wifiobd.ru/search
# Search-only ключ — получить по инструкции в DEVOPS.md раздел 6
NUXT_PUBLIC_MEILI_API_KEY=CHANGE_ME_search_only_key_from_meilisearch

# ── Docker Compose variable substitution ──────────────────────────────────────
# Используются в deploy/docker-compose.prod.yml для ${IMAGE_TAG} и ${CI_REGISTRY_IMAGE}
# deploy.sh экспортирует их из аргументов, но для ручного запуска нужны здесь:
CI_REGISTRY_IMAGE=registry.gitlab.wifiobd.ru/f2re/wifiobd2-site-modern
IMAGE_TAG=latest

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@wifiobd.ru

# ── Telegram уведомления ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Платёжные системы ────────────────────────────────────────────────────────
YOOMONEY_SHOP_ID=
YOOMONEY_SECRET=
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=
