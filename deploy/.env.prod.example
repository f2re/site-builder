# /srv/site-builder/.env.prod  — copy to server, fill in real values, chmod 600
# Never commit this file with real secrets!

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=sitebuilder
POSTGRES_USER=sb_user
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ── MeiliSearch ───────────────────────────────────────────────────────────────
MEILI_MASTER_KEY=CHANGE_ME_at_least_32_chars_long_key

# ── Backend app ───────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_django_or_jwt_secret
DATABASE_URL=postgresql+asyncpg://sb_user:CHANGE_ME_strong_db_password@postgres:5432/sitebuilder
REDIS_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379/0
MEILI_URL=http://meilisearch:7700
MEILI_API_KEY=CHANGE_ME_at_least_32_chars_long_key

# ── Docker registry (used by compose) ─────────────────────────────────────────
CI_REGISTRY_IMAGE=registry.gitlab.wifiobd.ru/f2re/wifiobd2-site-modern
IMAGE_TAG=latest
