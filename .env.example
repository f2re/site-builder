# .env.example — Template for all environment variables
# Copy to .env and fill in values. NEVER commit .env to git.
# See also: .gemini/agents/devops-agent.md for variable descriptions.

# ── Application ──────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-at-least-64-chars
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=site_builder
POSTGRES_USER=sb_user
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
TEST_DATABASE_URL=postgresql+asyncpg://sb_user:change-me@localhost:5432/site_builder_test

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Encryption (Fernet) for PD fields ────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-fernet-key

# ── CDEK v2 API ───────────────────────────────────────────────────────────────
CDEK_CLIENT_ID=your-cdek-client-id
CDEK_CLIENT_SECRET=your-cdek-client-secret
CDEK_API_URL=https://api.edu.cdek.ru/v2
# Production: https://api.cdek.ru/v2

# ── YooMoney ──────────────────────────────────────────────────────────────────
YOOMONEY_SHOP_ID=your-yoomoney-shop-id
YOOMONEY_SECRET_KEY=your-yoomoney-secret-key
# Sandbox: set YOOMONEY_SANDBOX=true for testing
YOOMONEY_SANDBOX=true

# ── Meilisearch ───────────────────────────────────────────────────────────────
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=change-me-meili-master-key

# ── Frontend (Nuxt 3) ─────────────────────────────────────────────────────────
NUXT_PUBLIC_API_BASE=http://localhost:8000
NUXT_PUBLIC_WS_BASE=ws://localhost:8000
NUXT_PUBLIC_MEILI_URL=http://localhost:7700
NUXT_PUBLIC_MEILI_SEARCH_KEY=your-meilisearch-search-only-key
